# Public site URL — used for canonical links, email content, and Stripe redirects.
NEXT_PUBLIC_SITE_URL=https://seoairegent.com

# Postgres connection string. On Railway, use the DATABASE_URL provided by the Postgres plugin.
DATABASE_URL=postgresql://user:password@localhost:5432/rankforge

# External providers
SERPER_API_KEY=
RESEND_API_KEY=
AUTH_RESET_EMAIL_FROM=hello@developer312.com

# Auth — session signing + admin MFA bootstrap
AUTH_SESSION_SECRET=
AUTH_ADMIN_EMAIL=admin@seoairegent.com
AUTH_ADMIN_PASSWORD_HASH=
AUTH_ADMIN_TOTP_SECRET=

# Password reset token signing (HMAC — must be distinct from AUTH_SESSION_SECRET)
AUTH_RESET_TOKEN_SECRET=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EDITOR_PRICE_ID=
STRIPE_EDITORIAL_PRICE_ID=
STRIPE_SYNDICATE_PRICE_ID=price_1TS6FoKGNA0NaemqhpwgcVAf

# Operational toggles
CACHE_DEBUG_ROUTE_ENABLED=false
CACHE_OBSERVABILITY_LOG_PATH=

# Analytics — Google Tag Manager container ID (e.g. GTM-XXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GTM_ID=

# Railway sets PORT and NODE_ENV automatically; do not override unless required.
